# App
APP_NAME=FastAPI App
APP_ENV=development
DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000

# Security
SECRET_KEY=change-me-with-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=facedetection
DB_USER=postgres
DB_PASSWORD=admin

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Storage
BASE_DIR=c:/projek/fastapi-fd
LOCAL_UPLOAD_DIR=c:/projek/fastapi-fd/uploads/local
OBJECT_UPLOAD_DIR=c:/projek/fastapi-fd/uploads/object
OBJECT_PUBLIC_BASE_URL=http://127.0.0.1:8000
