# App
APP_NAME=FastAPI App
APP_ENV=development
DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000

# Security
SECRET_KEY=change-me-with-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=facedetection
DB_USER=postgres
DB_PASSWORD=admin

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Storage
BASE_DIR=c:/projek/fastapi-fd
LOCAL_UPLOAD_DIR=c:/projek/fastapi-fd/uploads/local
OBJECT_UPLOAD_DIR=c:/projek/fastapi-fd/uploads/object
OBJECT_PUBLIC_BASE_URL=http://127.0.0.1:8000

# Face accuracy / inference
FACE_RECOGNITION_THRESHOLD=0.82
FACE_MIN_DETECTION_CONFIDENCE=0.7
FACE_MIN_BLUR_SCORE=20
FACE_MIN_BRIGHTNESS_SCORE=40
FACE_MAX_BRIGHTNESS_SCORE=220
FACE_EMBEDDING_PROVIDER=visual
# Use ONNX after installing model/dependencies, for example an ArcFace/InsightFace ONNX model.
# FACE_EMBEDDING_PROVIDER=onnx
# FACE_ONNX_MODEL_PATH=c:/projek/fastapi-fd/models/face_embedding.onnx
FACE_ONNX_INPUT_SIZE=112
FACE_ONNX_INPUT_NAME=
FACE_ONNX_OUTPUT_NAME=
FACE_ONNX_EXECUTION_PROVIDERS=CPUExecutionProvider
